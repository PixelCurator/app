      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle Alben"
          }
        }
      }
    },
    "All indexed photos are already sorted into albums. Keep indexing more photos to get suggestions here.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle indizierten Fotos sind bereits in Alben sortiert. Indiziere weitere Fotos, um hier Vorschläge zu erhalten."
